{
  "name": "appium-mocha-learning",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Minimal Android Appium tests with Mocha and WebdriverIO",
  "scripts": {
    "appium": "APPIUM_HOME=$PWD/.appium appium --allow-insecure=uiautomator2:chromedriver_autodownload",
    "driver:android:install": "APPIUM_HOME=$PWD/.appium appium driver install uiautomator2",
    "driver:list": "APPIUM_HOME=$PWD/.appium appium driver list --installed",
    "doctor:android": "APPIUM_HOME=$PWD/.appium appium driver doctor uiautomator2",
    "test:android": "node --env-file=.env ./node_modules/mocha/bin/mocha.js --timeout 120000 \"test/specs/android/**/*.spec.js\"",
    "test:android:wdio": "node --env-file=.env ./node_modules/@wdio/cli/bin/wdio.js run ./wdio.android.conf.js",
    "report:allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:allure:open": "allure open reports/allure-report",
    "report:allure:serve": "allure serve reports/allure-results"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "allure-commandline": "^2.43.0",
    "appium": "3.5.2",
    "mocha": "11.7.6",
    "webdriverio": "9.29.1"
  }
}
